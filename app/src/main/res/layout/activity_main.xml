<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml – Hauptlayout mit DartboardView, zwei Switches und Total-Feld.
  WICHTIG: Ersetze "com.example.dartapp" mit deinem echten Package-Namen falls nötig.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a1a"
    android:gravity="center_horizontal"
    android:paddingBottom="16dp">

    <!-- TITEL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DART APP"
        android:textColor="#e8c84a"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.3"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <!-- DARTBOARD (Custom View) -->
    <com.example.dartapp.DartboardView
        android:id="@+id/dartboardView"
        android:layout_width="340dp"
        android:layout_height="340dp"
        android:layout_marginTop="4dp" />

    <!-- TRENNLINIE -->
    <View
        android:layout_width="300dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"
        android:background="#333333" />

    <!-- SWITCHES ROW -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Double"
                android:textColor="#e0e0e0"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <Switch
                android:id="@+id/switchDouble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#e8c84a"
                android:trackTint="#444444" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Triple"
                android:textColor="#e0e0e0"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <Switch
                android:id="@+id/switchTriple"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#e8c84a"
                android:trackTint="#444444" />

        </LinearLayout>

    </LinearLayout>

    <!-- TOTAL SUM BEREICH -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOTAL PUNKTE"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/sumText"
            android:layout_width="180dp"
            android:layout_height="64dp"
            android:text="0"
            android:textColor="#e8c84a"
            android:textSize="38sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/sum_field_bg" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="120dp"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:text="RESET"
            android:textSize="12sp"
            android:textColor="#1a1a1a"
            android:backgroundTint="#e8c84a" />

    </LinearLayout>

</LinearLayout>
