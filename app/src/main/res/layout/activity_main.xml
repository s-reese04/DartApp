<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a1a"
    android:gravity="center_horizontal"
    android:paddingBottom="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DART APP"
        android:textColor="#e8c84a"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.3"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <com.example.dartapp.DartboardView
        android:id="@+id/dartboardView"
        android:layout_width="376dp"
        android:layout_height="390dp"
        android:layout_marginTop="4dp" />

    <View
        android:layout_width="300dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"
        android:background="#333333" />

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Double"
                android:textColor="#e0e0e0"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <Switch
                android:id="@+id/switchDouble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#e8c84a"
                android:trackTint="#444444" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Triple"
                android:textColor="#e0e0e0"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <Switch
                android:id="@+id/switchTriple"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#e8c84a"
                android:trackTint="#444444" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:letterSpacing="0.2"
            android:text="POINTS TOTAL"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/sumText"
            android:layout_width="180dp"
            android:layout_height="64dp"
            android:background="@drawable/sum_field_bg"
            android:gravity="center"
            android:text="301"
            android:textColor="#e8c84a"
            android:textSize="38sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="120dp"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#e8c84a"
            android:text="RESET"
            android:textColor="#1a1a1a"
            android:textSize="12sp" />

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/Players"
        android:layout_width="300dp"
        android:layout_height="53dp"
        android:layout_marginTop="12dp">

        <RadioGroup
            android:id="@+id/playerGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

</LinearLayout>
